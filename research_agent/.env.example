# Copy this file to .env and fill in your keys
# cp .env.example .env

# Required: Groq API key — get one free at https://console.groq.com
GROQ_API_KEY=Your Key here

# Optional: Tavily web search API key — get one at https://app.tavily.com
# If not set, the pipeline uses mock search results (great for demos)
TAVILY_API_KEY=Your Key here

# Optional: override the default Groq model
# GROQ_MODEL=llama-3.3-70b-versatile
